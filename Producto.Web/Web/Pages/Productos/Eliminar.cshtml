@page
@model Web.Pages.Productos.EliminarModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-primary text-white rounded-top-4">
                    <h4 class="mb-0">
                        <i class="bi bi-box-seam"></i> Detalle del Producto
                    </h4>
                </div>

                <div class="card-body p-4">

                    <h3 class="fw-bold text-primary">@Model.Producto.Nombre</h3>
                    <p class="text-muted">@Model.Producto.Descripcion</p>

                    <hr />

                    <div class="row g-3">

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100">
                                <small class="text-muted">Precio</small>
                                <h5 class="fw-bold text-success mb-0">
                                    ₡ @Model.Producto.Precio.ToString("N2")
                                </h5>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100">
                                <small class="text-muted">Precio en USD</small>
                                <h5 class="fw-bold text-success mb-0">
                                    $ @Model.Producto.PrecioUSD.ToString("N2")
                                </h5>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100">
                                <small class="text-muted">Stock disponible</small>

                                @if (Model.Producto.Stock == 0)
                                {
                                    <span class="badge bg-danger">Agotado</span>
                                }
                                else if (Model.Producto.Stock < 10)
                                {
                                    <span class="badge bg-warning text-dark">Stock bajo</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Disponible</span>
                                }

                                <h5 class="fw-bold mb-0 mt-2">
                                    @Model.Producto.Stock unidades
                                </h5>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100">
                                <small class="text-muted">Código de barras</small>
                                <h6 class="fw-bold mb-0">
                                    @Model.Producto.CodigoBarras
                                </h6>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100">
                                <small class="text-muted">Categoría</small>
                                <h6 class="fw-bold mb-0">
                                    @Model.Producto.Categoria
                                </h6>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100">
                                <small class="text-muted">Subcategoría</small>
                                <h6 class="fw-bold mb-0">
                                    @Model.Producto.SubCategoria
                                </h6>
                            </div>
                        </div>

                    </div>
                </div>

                <form method="post" class="card-footer bg-light text-end rounded-bottom-4">
                    <a asp-page="./Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <input type="hidden" asp-for="Producto.Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash-fill"></i> Eliminar
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>